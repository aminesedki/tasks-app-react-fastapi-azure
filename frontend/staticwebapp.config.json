{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/assets/*",
            "/*.{css,js,png,jpg,jpeg,gif,svg,ico,webp,map,json,txt,woff,woff2}"
        ]
    },
    "globalHeaders": {
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin"
    }
}